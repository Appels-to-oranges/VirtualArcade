# Railway PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:port/database

# Session secret (use a long random string in production)
SESSION_SECRET=change-me-to-a-random-secret

# Set to 'production' on Railway
NODE_ENV=development

# Google OAuth (optional – buttons hidden if not set)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Discord OAuth (optional – buttons hidden if not set)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
